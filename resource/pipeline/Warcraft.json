                "roi":[740,640,120,40]
            }
        },
        "action":{
            "type":"Click"
        },
        "next":[
            "WarcraftSetMax"
        ]
    },

    "WarcraftSetMax":{
        "recognition": {
            "type": "OCR",
            "param": {
                "template": "MAX",
                "threshold": 0.60,
                "roi":[740,350,80,50]
            }
        },
        "action":{
            "type":"click"
        },
        "next":[
            "WarcraftBegin"
        ]
    },

    "WarcraftBegin":{
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": "战斗",
                "threshold": 0.80,
                "roi":[640,530,60,40]
            }
        },
        "action":{
            "type":"click"
        },
        "next":[
            "StartGame"
        ]
    }
